# Frontend base URL allowed by backend CORS (optional in local dev)
FRONTEND_ORIGIN=http://localhost:8080

# Auth token settings
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# SMTP email settings for signup confirmation
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
FROM_EMAIL=XOps Team <your-email@example.com>
