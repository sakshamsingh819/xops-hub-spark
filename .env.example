# Backend API
PORT=4000
JWT_SECRET=replace-with-a-strong-secret
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
DB_SSL=true
FRONTEND_ORIGIN=

# Optional: any signup with this email becomes admin.
# If left empty, and no admin exists yet, the next signup becomes admin.
ADMIN_EMAIL=

# Frontend (Vercel)
VITE_API_BASE_URL=
