# Backend API
PORT=4000
JWT_SECRET=replace-with-a-strong-secret
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
DB_SSL=true
FRONTEND_ORIGIN=

# Only this exact email can have admin access.
# If left empty, everyone is treated as a regular member.
ADMIN_EMAIL=

# Frontend (Vercel)
VITE_API_BASE_URL=
